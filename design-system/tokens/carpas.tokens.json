{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "КарПас MVP — токены из src/index.css, src/App.css, tailwind.config.js. Импорт в Figma: плагин Tokens Studio → Import → JSON.",
  "color": {
    "bg": { "$value": "#16171d", "$type": "color", "$description": ":root --bg" },
    "text": { "$value": "#9ca3af", "$type": "color", "$description": "основной текст" },
    "textHeading": { "$value": "#f3f4f6", "$type": "color", "$description": "заголовки, контрастный текст" },
    "border": { "$value": "#2e303a", "$type": "color" },
    "codeBg": { "$value": "#1f2028", "$type": "color" },
    "accent": { "$value": "#c084fc", "$type": "color", "$description": "primary, ссылки, фокус" },
    "accentBg": { "$value": "rgba(192, 132, 252, 0.15)", "$type": "color" },
    "accentBorder": { "$value": "rgba(192, 132, 252, 0.5)", "$type": "color" },
    "openAction": { "$value": "#5eead4", "$type": "color", "$description": "бирюза «открыть»" },
    "muted": { "$value": "#8b92a3", "$type": "color" },
    "socialBg": { "$value": "rgba(47, 48, 58, 0.5)", "$type": "color" },
    "white": { "$value": "#ffffff", "$type": "color" },
    "danger": { "$value": "#ff3b3b", "$type": "color", "$description": "кнопка danger (база смешивания)" },
    "cardFill": { "$value": "#181920", "$type": "color", "$description": "приближение к .card (mix bg + code-bg)" },
    "overlayDark": { "$value": "rgba(12, 12, 16, 0.58)", "$type": "color", "$description": "heroCoverStat overlay" }
  },
  "dimension": {
    "radius": {
      "sm": { "$value": "4px", "$type": "dimension", "$description": "code" },
      "md": { "$value": "12px", "$type": "dimension", "$description": "кнопки, input, nav" },
      "lg": { "$value": "14px", "$type": "dimension", "$description": "combo menu, hero stat" },
      "xl": { "$value": "16px", "$type": "dimension", "$description": ".card" },
      "pill": { "$value": "999px", "$type": "dimension" }
    },
    "space": {
      "2": { "$value": "8px", "$type": "dimension" },
      "2.5": { "$value": "10px", "$type": "dimension" },
      "3": { "$value": "12px", "$type": "dimension" },
      "3.5": { "$value": "14px", "$type": "dimension" },
      "4": { "$value": "16px", "$type": "dimension" },
      "5": { "$value": "20px", "$type": "dimension" },
      "5.5": { "$value": "22px", "$type": "dimension" },
      "6": { "$value": "24px", "$type": "dimension" },
      "7": { "$value": "28px", "$type": "dimension" }
    },
    "layout": {
      "maxContent": { "$value": "1126px", "$type": "dimension", "$description": ".nav__inner" },
      "touchMin": { "$value": "44px", "$type": "dimension", "$description": "min-height кликабельных зон" }
    }
  },
  "fontFamily": {
    "sans": { "$value": "Roboto, system-ui, sans-serif", "$type": "fontFamily", "$description": "tailwind + index" },
    "heading": { "$value": "system-ui, Segoe UI, Roboto, sans-serif", "$type": "fontFamily" },
    "mono": { "$value": "ui-monospace, Consolas, monospace", "$type": "fontFamily" }
  },
  "fontSize": {
    "xs": { "$value": "12px", "$type": "dimension", "$description": "field hint" },
    "sm": { "$value": "13px", "$type": "dimension", "$description": "pill" },
    "base": { "$value": "14px", "$type": "dimension" },
    "body": { "$value": "15px", "$type": "dimension", "$description": "кнопки, поля" },
    "bodyRoot": { "$value": "18px", "$type": "dimension", "$description": ":root, ≤1024px → 16px" },
    "bodyRootMobile": { "$value": "16px", "$type": "dimension" },
    "h2": { "$value": "20px", "$type": "dimension" },
    "h1": { "$value": "32px", "$type": "dimension" }
  },
  "fontWeight": {
    "semibold": { "$value": "600", "$type": "fontWeight", "$description": "h1, h2" },
    "label": { "$value": "650", "$type": "fontWeight", "$description": "field label, nav brand" }
  },
  "lineHeight": {
    "tight": { "$value": "1.1", "$type": "number", "$description": "h1" },
    "snug": { "$value": "1.2", "$type": "number", "$description": "h2, кнопки" },
    "body": { "$value": "1.45", "$type": "number", "$description": ":root" },
    "field": { "$value": "1.3", "$type": "number", "$description": "input" }
  },
  "letterSpacing": {
    "body": { "$value": "0.18px", "$type": "dimension" },
    "h1": { "$value": "-0.8px", "$type": "dimension" },
    "h2": { "$value": "-0.2px", "$type": "dimension" }
  },
  "opacity": {
    "disabled": { "$value": "0.55", "$type": "number", "$description": "кнопки disabled" }
  },
  "shadow": {
    "card": {
      "$value": "0 10px 15px -3px rgba(0,0,0,0.4), 0 4px 6px -2px rgba(0,0,0,0.25)",
      "$type": "other",
      "$description": "CSS box-shadow из :root --shadow; в Figma — два Drop shadow или один слой по вкусу"
    }
  },
  "number": {
    "motionFast": { "$value": "120", "$type": "number", "$description": "transition ms" },
    "zNav": { "$value": "5", "$type": "number" },
    "zModal": { "$value": "20", "$type": "number", "$description": "cb__menu" }
  },
  "component": {
    "button": {
      "paddingX": { "$value": "12px", "$type": "dimension" },
      "paddingY": { "$value": "10px", "$type": "dimension" },
      "gap": { "$value": "8px", "$type": "dimension" }
    },
    "card": {
      "padding": { "$value": "22px 24px", "$type": "dimension", "$description": ".pad — в Figma два токена или auto-layout" }
    },
    "field": {
      "gap": { "$value": "8px", "$type": "dimension" }
    }
  }
}
