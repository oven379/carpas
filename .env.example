# Необязательно: если фронт открывают не в браузере (превью), для абсолютных URL в JSON-LD.
# В браузере canonical и og берутся из window.location.origin.
# Пример: https://carpas.ru  (без слэша в конце)
VITE_SITE_ORIGIN=

# Мобильное приложение (Capacitor): полный URL API, без слэша в конце пути /api.
# Эмулятор Android + Docker на ПК: http://10.0.2.2:8088/api
# Продакшен: https://ваш-домен.ru/api
# VITE_API_BASE_URL=http://10.0.2.2:8088/api
