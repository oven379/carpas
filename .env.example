## Базовый URL Laravel API (без завершающего слэша).
## В dev лучше не задавать переменную — тогда используется прокси Vite → :8088.
## Не используйте http://localhost/api без порта: запросы уйдут на :80, не на Docker/nginx.
# VITE_API_BASE_URL=http://127.0.0.1:8088/api

## Куда проксировать /api и /storage (dev/preview), если nginx не на 8088
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:8088
