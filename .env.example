# Канонический домен для SEO: canonical, Open Graph, JSON-LD и sitemap.
# На сервере http://carpass.ru и https://carpass.ru нужно редиректить на этот URL.
VITE_SITE_ORIGIN=https://www.carpass.ru

# Верификация поисковых кабинетов. Значения берутся из Google Search Console и Яндекс.Вебмастера.
VITE_GOOGLE_SITE_VERIFICATION=
VITE_YANDEX_VERIFICATION=

# Мобильное приложение (Expo): полный URL API, без слэша в конце пути /api.
# Эмулятор Android + Docker на ПК: http://10.0.2.2:8088/api
# Продакшен: https://ваш-домен.ru/api
# ОБЯЗАТЕЛЬНО для сборки в Play Market / App Store:
#   1. Скопируй .env.example → .env.production.local (он в .gitignore)
#   2. Пропиши реальный URL: VITE_API_BASE_URL=https://ваш-домен.ru/api
#   3. cd expo && npm install && npm run android / eas build
# VITE_API_BASE_URL=https://ваш-домен.ru/api

# DaData: подсказки при выборе города (API подсказок по адресам, гранулярность «город»).
# Документация: https://dadata.ru/api/suggest/address/
# Ключ «API-ключ» из личного кабинета DaData. Попадает в клиентский бундл — для продакшена при желании вынесите вызов на бэкенд.
# Файл .env или .env.local в корне фронта; после изменения: перезапуск npm run dev или заново npm run build.
# Не коммитьте ключ.
VITE_DADATA_TOKEN=
