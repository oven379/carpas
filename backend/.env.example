APP_NAME=CarPassport
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8088

# Публичные файлы: php artisan storage:link → storage/app/public доступен как /storage/...
# Медиа из data URI сохраняются под storage/app/public/media (см. media:migrate-embedded).
MEDIA_MAX_BYTES=12582912

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=car_passport
DB_USERNAME=car_passport
DB_PASSWORD=car_passport

REDIS_HOST=redis
REDIS_PORT=6379

SESSION_DRIVER=redis
CACHE_DRIVER=redis
QUEUE_CONNECTION=sync

