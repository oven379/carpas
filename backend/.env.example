APP_NAME=CarPassport
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8088

# Публичные файлы: php artisan storage:link → storage/app/public доступен как /storage/...
# Медиа из data URI сохраняются под storage/app/public/media (см. media:migrate-embedded).
MEDIA_MAX_BYTES=12582912

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=car_passport
DB_USERNAME=car_passport
DB_PASSWORD=car_passport

REDIS_HOST=redis
REDIS_PORT=6379

SESSION_DRIVER=redis
CACHE_DRIVER=redis
QUEUE_CONNECTION=sync

# Поддержка: вход в админку тикетов (POST /api/admin/support/login) и Bearer для GET/POST admin/support/*.
# Скопируйте в .env и задайте свои значения; на проде — сложный пароль и длинный случайный токен (не коммитьте .env).
ADMIN_SUPPORT_LOGIN=admin_support
ADMIN_SUPPORT_PASSWORD=change-me
ADMIN_SUPPORT_BEARER_TOKEN=change-me-long-random-bearer-token

# Firebase Cloud Messaging (HTTP v1) — push на Android/iOS из админки (POST /api/admin/support/push/broadcast).
# В консоли Firebase: Project settings → Service accounts → Generate new private key → JSON-файл.
FIREBASE_PROJECT_ID=
# Абсолютный путь к JSON на сервере (например /var/secrets/firebase.json) или оставьте пустым и используйте B64:
FIREBASE_CREDENTIALS_PATH=
# Base64 от содержимого JSON (удобно в Docker / CI):
FIREBASE_CREDENTIALS_B64=

